{
  "manifest_version": 3,
  "name": "Remove Judol Ads",
  "version": "2.2.0",
  "description": "Menghapus elemen iklan judol berupa <a> yang berisi <img>, overlay ads, blokir popup ke situs judol, dan anti pindah tab",
  "permissions": ["storage", "activeTab", "tabs", "webNavigation"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Remove Judol Ads",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js", "picker.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
